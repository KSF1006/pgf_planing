<div class="p-4 flex justify-between">
  <div>
    <%= link_to "Home", root_path, class: "font-semibold" %>
  </div>

  <div>
    <% if user_signed_in? %>
      <span class="mr-4"><%= current_user.email %></span>
      <%= link_to "Logout",
          destroy_user_session_path,
          data: { turbo_method: :delete },
          class: "text-red-600" %>
    <% else %>
      <%= link_to "Sign up",
          new_user_registration_path,
          class: "mr-4 text-blue-600" %>
      <%= link_to "Login",
          new_user_session_path,
          class: "text-blue-600" %>
    <% end %>
  </div>
</div>