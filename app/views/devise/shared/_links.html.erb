<div class="flex flex-col sm:flex-row sm:justify-between gap-2 text-sm mt-4">
  <%# Log in link if not on sessions page %>
  <% if controller_name != 'sessions' %>
    <%= link_to "Log in", new_session_path(resource_name), class: "text-blue-600 hover:underline" %>
  <% end %>

  <%# Sign up link if registerable and not on registrations page %>
  <% if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Sign up", new_registration_path(resource_name), class: "text-blue-600 hover:underline" %>
  <% end %>

  <%# Forgot password link if recoverable and not on passwords/registrations pages %>
  <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-blue-600 hover:underline" %>
  <% end %>

  <%# Resend confirmation if confirmable and not on confirmations page %>
  <% if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "text-blue-600 hover:underline" %>
  <% end %>

  <%# Unlock instructions if lockable and unlock via email %>
  <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "text-blue-600 hover:underline" %>
  <% end %>

  <%# OmniAuth providers if omniauthable %>
  <% if devise_mapping.omniauthable? %>
    <% resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider),
          class: "text-white bg-gray-700 hover:bg-gray-800 py-1 px-3 rounded-md transition text-sm",
          data: { turbo: false } %>
    <% end %>
  <% end %>
</div>